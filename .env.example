# ZERUX IA (iachat-v2 tree) — copy to .env and adjust (never commit .env)
# Ports: v1 uses Vite 7597 + API 7598; v2 uses Vite 7598 + API 7608

PORT=7608

# MariaDB — DB_USER / DB_NAME are usually the same app id (e.g. iachat-v2).
# Password is read from /apps/{DB_NAME}/etc/mysql/localhost/passwd when that file exists.
# Example on zeruxcomm host (schema in shared DB): DB_USER=zeruxcomm-v1 DB_NAME=zeruxcomm-v1
DB_USER=iachat-v2
DB_NAME=iachat-v2
# DB_PASSWORD=only_if_no_passwd_file

JWT_SECRET=change-me-in-production

# vLLM (OpenAI-compatible API: POST /v1/chat/completions)
OLLAMA_ENABLED=1
OLLAMA_BASE_URL=http://localhost:8000
OLLAMA_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ
# Comma-separated hints if /v1/models fails (server-side fallback for the admin model list)
# OLLAMA_FALLBACK_MODELS=Qwen/Qwen2.5-32B-Instruct-AWQ,google/gemma-4-E4B-it
# Optional Vite build-time hints for the admin UI when GET /api/admin/ollama-settings fails (comma-separated)
# VITE_OLLAMA_MODEL_HINTS=Qwen/Qwen2.5-32B-Instruct-AWQ
# Optional system prompt for every conversation
# OLLAMA_SYSTEM_PROMPT=You are a helpful assistant. Reply concisely.

# Optional: override skin/plugin dirs (defaults: ./skins and ./plugins next to server/)
# SKINS_DIR=/custom/path/skins
# PLUGINS_DIR=/custom/path/plugins

# Optional: file uploads directory (default: ./tmp/uploads under the app)
# UPLOAD_DIR=/apps/iachat-v2/app/tmp/uploads
