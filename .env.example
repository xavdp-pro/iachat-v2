# IAChat v2 — copy to .env and adjust (never commit .env)
# Ports: v1 uses Vite 7597 + API 7598; v2 uses Vite 7598 + API 7608

PORT=7608

# MariaDB (defaults match /apps/iachat-v2 convention: user & DB name = iachat-v2)
# Password is read from /apps/iachat-v2/etc/mysql/localhost/passwd when present
DB_USER=iachat-v2
DB_NAME=iachat-v2
# DB_PASSWORD=only_if_no_passwd_file

JWT_SECRET=change-me-in-production
